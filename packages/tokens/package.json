{
  "name": "@kamijeong/tokens",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kamijeong/generate-with-spec-kit.git",
    "directory": "packages/tokens"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "dist",
    "src/css/base.css",
    "src/css/base.css.d.ts",
    "README.md",
    "package.json"
  ],
  "sideEffects": [
    "./src/css/base.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tailwind": {
      "types": "./dist/tailwind/preset.d.ts",
      "import": "./dist/tailwind/preset.js",
      "require": "./dist/tailwind/preset.cjs"
    },
    "./css": {
      "types": "./src/css/base.css.d.ts",
      "style": "./src/css/base.css",
      "import": "./src/css/base.css",
      "require": "./src/css/base.css"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage",
    "lint": "eslint src tests scripts --ext .ts",
    "check-contrast": "tsx scripts/check-contrast.ts"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@vitest/coverage-v8": "^3.1.1",
    "eslint": "^9.24.0",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "@fontsource/noto-sans-kr": "^5.2.9",
    "pretendard": "^1.3.9"
  }
}
